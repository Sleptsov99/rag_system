# Telegram bot
TELEGRAM_BOT_TOKEN=your_token_here
# Comma-separated Telegram user IDs that have admin rights
TELEGRAM_ADMIN_IDS=452095992

# LLM backend: "groq" (free, fast) | "openai" | "ollama" (local)
LLM_PROVIDER=groq

# Groq (free): get key at https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (paid, optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama (local only)
# OLLAMA_MODEL=llama3.2:1b
# OLLAMA_URL=http://localhost:11434
